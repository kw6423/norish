{
  "name": "@norish/web",
  "version": "0.18.1-beta",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "build": "pnpm run build:web && pnpm run build:server && pnpm run update-sw",
    "build:web": "next build",
    "build:server": "tsdown --config ./tsdown.config.ts",
    "update-sw": "node scripts/update-sw-version.js",
    "start": "node ../../dist-server/index.mjs",
    "test": "vitest --config ./vitest.config.ts",
    "test:run": "vitest run --config ./vitest.config.ts",
    "test:coverage": "vitest run --coverage --config ./vitest.config.ts",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "typecheck": "pnpm exec tsc --noEmit",
    "clean": "git clean -xdf .cache .next .turbo node_modules dist"
  },
  "dependencies": {
    "@better-auth/api-key": "catalog:",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@heroicons/react": "catalog:",
    "@heroui/avatar": "^2.2.26",
    "@heroui/dropdown": "^2.3.32",
    "@heroui/navbar": "^2.2.30",
    "@heroui/react": "catalog:",
    "@heroui/system": "^2.4.28",
    "@heroui/theme": "^2.4.26",
    "@heroui/toast": "^2.0.22",
    "@iconify/react": "^6.0.2",
    "@internationalized/date": "^3.12.0",
    "@norish/api": "workspace:*",
    "@norish/auth": "workspace:*",
    "@norish/config": "workspace:*",
    "@norish/db": "workspace:*",
    "@norish/i18n": "workspace:*",
    "@norish/queue": "workspace:*",
    "@norish/shared": "workspace:*",
    "@norish/shared-react": "workspace:*",
    "@norish/shared-server": "workspace:*",
    "@norish/trpc": "workspace:*",
    "@norish/ui": "workspace:*",
    "@scalar/nextjs-api-reference": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@tanstack/react-virtual": "^3.13.23",
    "@trpc/client": "catalog:",
    "@trpc/server": "catalog:",
    "@trpc/tanstack-react-query": "catalog:",
    "better-auth": "catalog:",
    "date-fns": "catalog:",
    "motion": "12.34.2",
    "next": "catalog:",
    "next-intl": "^4.8.3",
    "next-themes": "0.4.6",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-markdown": "^10.1.0",
    "server-only": "catalog:",
    "use-sound": "^5.0.0",
    "usehooks-ts": "^3.1.1",
    "ws": "catalog:",
    "zustand": "5.0.11"
  },
  "devDependencies": {
    "@norish/eslint-config": "workspace:*",
    "@norish/prettier-config": "workspace:*",
    "@norish/tailwind-config": "workspace:*",
    "@norish/tsconfig": "workspace:*",
    "@tailwindcss/postcss": "catalog:",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "eslint": "catalog:",
    "jsdom": "catalog:",
    "postcss": "catalog:",
    "prettier": "catalog:",
    "tailwindcss": "catalog:",
    "tsdown": "^0.20.3",
    "tsx": "4.21.0",
    "vitest": "catalog:"
  },
  "prettier": "@norish/prettier-config"
}
