{
  "name": "@norish/shared",
  "version": "0.18.1-beta",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./contracts": "./src/contracts/index.ts",
    "./contracts/recurrence": "./src/contracts/recurrence.ts",
    "./contracts/zod": "./src/contracts/zod/index.ts",
    "./contracts/dto/auth": "./src/contracts/dto/auth.ts",
    "./contracts/dto/*": "./src/contracts/dto/*.d.ts",
    "./contracts/*": "./src/contracts/*.ts",
    "./lib/*": "./src/lib/*.ts"
  },
  "scripts": {
    "build": "rm -rf dist && pnpm exec tsc -p tsconfig.json --noCheck",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "typecheck": "pnpm exec tsc --noEmit",
    "clean": "git clean -xdf .cache .turbo node_modules dist",
    "test": "vitest run --config ./vitest.config.ts"
  },
  "dependencies": {
    "@norish/config": "workspace:*",
    "@norish/db": "workspace:*",
    "@tanstack/react-query": "catalog:",
    "@trpc/client": "catalog:",
    "@trpc/server": "catalog:",
    "@trpc/tanstack-react-query": "catalog:",
    "@better-auth/api-key": "catalog:",
    "better-auth": "catalog:",
    "date-fns": "catalog:",
    "drizzle-zod": "0.8.3",
    "fraction.js": "^5.3.4",
    "html-entities": "catalog:",
    "jsonrepair": "3.13.2",
    "parse-ingredient": "2.1.0",
    "react": "catalog:",
    "superjson": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@norish/eslint-config": "workspace:*",
    "@norish/prettier-config": "workspace:*",
    "@norish/tsconfig": "workspace:*",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "jsdom": "catalog:",
    "vitest": "catalog:"
  },
  "prettier": "@norish/prettier-config"
}
