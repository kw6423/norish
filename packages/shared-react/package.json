{
  "name": "@norish/shared-react",
  "version": "0.18.1-beta",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./hooks": "./src/hooks/index.ts",
    "./hooks/groceries": "./src/hooks/groceries/index.ts",
    "./hooks/households": "./src/hooks/households/index.ts",
    "./hooks/ratings": "./src/hooks/ratings/index.ts",
    "./hooks/recipes": "./src/hooks/recipes/index.ts",
    "./hooks/recipes/dashboard": "./src/hooks/recipes/dashboard/index.ts",
    "./hooks/recipes/recipe": "./src/hooks/recipes/recipe/index.ts",
    "./hooks/use-user": "./src/hooks/use-user.ts",
    "./contexts": "./src/contexts/index.ts",
    "./providers": "./src/providers/index.ts"
  },
  "scripts": {
    "build": "rm -rf dist && pnpm exec tsc -p tsconfig.json --noCheck",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "typecheck": "pnpm exec tsc --noEmit --noCheck",
    "clean": "git clean -xdf .cache .turbo node_modules dist",
    "test": "vitest run --config ./vitest.config.ts"
  },
  "dependencies": {
    "@norish/config": "workspace:*",
    "@norish/i18n": "workspace:*",
    "@norish/shared": "workspace:*",
    "@norish/trpc": "workspace:*",
    "@tanstack/react-query": "catalog:",
    "@trpc/client": "catalog:",
    "@trpc/server": "catalog:",
    "@trpc/tanstack-react-query": "catalog:",
    "react": "catalog:",
    "superjson": "catalog:"
  },
  "devDependencies": {
    "@norish/eslint-config": "workspace:*",
    "@norish/prettier-config": "workspace:*",
    "@norish/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "eslint": "catalog:",
    "jsdom": "catalog:",
    "prettier": "catalog:",
    "vitest": "catalog:"
  },
  "prettier": "@norish/prettier-config"
}
